# TRINETRA AI - Trade Fraud Intelligence System
# Environment Variables Configuration

# =============================================================================
# AI/ML Configuration
# =============================================================================

# Gemini API Key for AI-powered fraud explanations
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Configuration
GEMINI_MODEL=models/gemini-2.5-flash
GEMINI_TIMEOUT=10

# =============================================================================
# API Configuration
# =============================================================================

# FastAPI Backend Settings
API_HOST=localhost
API_PORT=8000
API_RELOAD=true

# CORS Settings
CORS_ORIGINS=*
CORS_METHODS=*
CORS_HEADERS=*

# =============================================================================
# Application Settings
# =============================================================================

# Data File Path
DATASET_PATH=data/trinetra_trade_fraud_dataset_1000_rows_complex.csv

# Model Storage Path
MODEL_PATH=models/isolation_forest.pkl

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=trinetra.log

# =============================================================================
# ML Model Configuration
# =============================================================================

# IsolationForest Parameters
ISOLATION_FOREST_N_ESTIMATORS=100
ISOLATION_FOREST_CONTAMINATION=0.1
ISOLATION_FOREST_RANDOM_STATE=42

# Risk Classification Thresholds
RISK_THRESHOLD_SAFE=-0.2
RISK_THRESHOLD_FRAUD=0.2

# =============================================================================
# Alert System Configuration
# =============================================================================

# Alert Trigger Thresholds
ALERT_PRICE_DEVIATION_THRESHOLD=0.5
ALERT_COMPANY_RISK_THRESHOLD=0.8
ALERT_PORT_ACTIVITY_THRESHOLD=1.5

# =============================================================================
# Dashboard Configuration
# =============================================================================

# Streamlit Settings
STREAMLIT_HOST=localhost
STREAMLIT_PORT=8501
STREAMLIT_THEME=dark

# Dashboard Refresh Interval (seconds)
DASHBOARD_REFRESH_INTERVAL=30

# =============================================================================
# Development Settings
# =============================================================================

# Environment Mode
ENVIRONMENT=development

# Debug Mode
DEBUG=true

# Enable/Disable Features
ENABLE_AI_EXPLANATIONS=true
ENABLE_ALERTS=true
ENABLE_CACHING=true